# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging output
build/
dist/
site/
.eggs/
*.egg-info/
pip-wheel-metadata/

# Test, lint, and type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Local environment and secret-bearing config
.env
.env.*
!.env.example
*.local
*.secret
*.secrets.*

# Keys, certificates, and credential bundles
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.kdbx

# Logs and local runtime artifacts
*.log
*.out
*.pid
*.pid.lock

# Editor and OS files
.DS_Store
Thumbs.db
.idea/
.vscode/

# Optional local inputs or scratch files
tmp/
.tmp/
