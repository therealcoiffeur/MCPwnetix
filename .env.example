# Copy this file to `.env`, then set the values in this first section for your environment.

# Point this at the Acunetix API reachable from the MCP container or process.
# Examples:
#   https://host.docker.internal:3443/api/v1
ACUNETIX_BASE_URL=https://host.docker.internal:3443/api/v1
ACUNETIX_API_KEY=replace_with_acunetix_api_key
# Only set this if your Acunetix deployment needs the `ui_session` cookie.
ACUNETIX_UI_SESSION=
# This shared token must match `ACUNETIX_MCP_AUTH_TOKEN` in `GhostReconRev/.env`.
ACUNETIX_MCP_AUTH_TOKEN=replace_with_shared_mcp_token

# The remaining values are predefined MCP and Acunetix client defaults.
# Adjust them only if your deployment needs different transport or server settings.

ACUNETIX_ALLOW_INSECURE_HTTP=false
ACUNETIX_TIMEOUT_SECONDS=30
ACUNETIX_RETRY_ATTEMPTS=3
ACUNETIX_RETRY_BACKOFF_SECONDS=0.5
ACUNETIX_RETRY_UNSAFE_METHODS=false
ACUNETIX_VERIFY_SSL=true
ACUNETIX_MAX_BINARY_BYTES=1048576
ACUNETIX_MCP_MAX_MESSAGE_BYTES=1048576
ACUNETIX_MCP_BIND_HOST=0.0.0.0
ACUNETIX_MCP_PORT=3000
ACUNETIX_MCP_PATH=/mcp
ACUNETIX_LOG_LEVEL=INFO
# Optional override for the outbound Acunetix API user agent. Leave unset to use the built-in default.
ACUNETIX_USER_AGENT=
